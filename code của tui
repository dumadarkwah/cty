void TriggerNormalStageStart() {

//Kiểm tra state hiện tại có thuộc Normal hay không
if (State.Now == NML || State.Now == ZEN || State.Now == HYR) {
//NML開始時初期化処理 khởi tại trạng thái
InitializeNormalStageState();

//Bật cờ hiển thị tiêu đề
TitleDisplayFlag = TRUE;

//BIG示唆抽せん			
int bigHint = xoSo();

//CASE 1: bigHint >= 11 (cao)
if (bigHint >= 11) {
BigHintGameCountType = TYPE_16; 
bigHint -= 10; } 

//CASE 2: bigHint >= 1 (thấp)
else if (bigHint >= 1) {
//BIG示唆ｹﾞｰﾑ数抽せん
BigHintGameCountType = GetBigHintGameCountRandom(); }

//朝一1G目だけﾌﾗｸﾞ]=1?
if (isFirstGame == FALSE) {
bool giuStage = false;
bool thietLapStage = false; 
//Cái này có nghĩa là nếu không phải game đầu buổi sáng thì mặc định không cần giữ stage và không cần set stage mới luôn


//Kiểm tra trạng thái của game trước đó
if (State.Old >= MBT) {
//xét trường hợp đặc biệt: BKZ + MBT_TYPE
if (State.Old == BKZ && OldBKZType == MBT_TYPE) {
//Nếu là trường hợp đặc biệt thì giữ stage BKZ
CurrentStage = BKZStage;
keepStage = true; }

else {
//Nếu không phải trường hợp đặc biệt thì random lại khi không dính cả 2
CZFlag = FALSE;    // Hủy CZ mode
ItemFlag = FALSE;  // Hủy item bonus
CurrentStage == GetRandomStage; 
}

 }

}
}
